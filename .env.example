# =============================================================================
# WieNet - Umgebungsvariablen
# Kopieren nach .env und Werte für den produktiven Einsatz anpassen.
# Die docker-compose.yml enthält funktionierende Entwicklungs-Defaults,
# falls diese Datei nicht angelegt wird - für den produktiven Betrieb aber
# UNBEDINGT eigene, sichere Werte setzen.
# =============================================================================

# --- PostgreSQL / PostGIS ---
POSTGRES_DB=wienet
POSTGRES_USER=wienet
POSTGRES_PASSWORD=change_me_strong_password

# Muss zu den drei Werten oben passen (Format: postgresql+psycopg://USER:PASSWORT@db:5432/DB)
DATABASE_URL=postgresql+psycopg://wienet:change_me_strong_password@db:5432/wienet

# --- Backend / Sicherheit ---
# Generieren mit: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Erst-Admin (wird beim ersten Start automatisch angelegt, falls E-Mail noch nicht existiert) ---
ADMIN_EMAIL=admin@wsmronline.uk
ADMIN_PASSWORD=change_me_strong_password

# --- CORS: Domain(s), über die das Frontend erreichbar ist (kommagetrennt) ---
CORS_ORIGINS=https://tiefbau.wsmronline.uk,http://localhost:8093

